V8_APP_ENV=development
V8_DATABASE_URL=sqlite:///./excelbase_v8.db
V8_ALLOW_DEV_IDENTITY=1
V8_AUTO_CREATE_SCHEMA=1
# Tek anahtar: V8_FIELD_ENCRYPTION_KEY, ya da rotasyon destekli çoklu anahtar:
# V8_FIELD_ENCRYPTION_KEYS=k2:YENI_FERNET_KEY,k1:ESKI_FERNET_KEY  (ilki aktiftir)
V8_FIELD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY
V8_PASSPORT_HMAC_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
V8_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
V8_MAX_IMPORT_BYTES=20971520
V8_MAX_PHOTO_BYTES=5242880

# JWT (production'da zorunlu; scripts/issue_token.py ile token üretilebilir)
V8_JWT_SECRET=
V8_JWT_ISSUER=excelbase-v8
V8_JWT_AUDIENCE=excelbase-v8

# Obje depolama: local (geliştirme) veya s3 (production / R2 / MinIO)
V8_STORAGE_BACKEND=local
V8_STORAGE_LOCAL_ROOT=./objects
V8_S3_BUCKET=
V8_S3_REGION=
V8_S3_ENDPOINT_URL=
V8_S3_PREFIX=

# Rate limiting
V8_RATE_LIMIT_ENABLED=1
V8_RATE_LIMIT_IMPORT_PER_MINUTE=10
V8_RATE_LIMIT_REVEAL_PER_MINUTE=30
