# Copy to deploy/oracle/.env and replace every CHANGE_ME value.
# Never commit or send the resulting .env file through chat/email.

# A DNS A record for this hostname must point to the OCI VM public IPv4.
APP_DOMAIN=excelbase.example.com
ACME_EMAIL=operator@example.com
TZ=Europe/Istanbul

# Use only URL-safe characters for the database password because it is also
# interpolated into DATABASE_URL.  `openssl rand -hex 32` is suitable.
POSTGRES_DB=excelbase_v7
POSTGRES_USER=excelbase
POSTGRES_PASSWORD=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32

# The data secret encrypts the app's daily snapshots; losing it makes those
# snapshots unreadable. When migrating from Render, copy the EXISTING value.
GATEVISA_DATA_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32

# Do not configure GATEVISA_API_KEY on the public V7 deployment. Same-origin
# HttpOnly session cookies protect passenger and photo requests without
# putting an administrator-equivalent secret into URLs.

# Automatic local dump retention.  Off-VM copies are still mandatory.
BACKUP_RETENTION_DAYS=14

# Recommended before cutover. The VM writes with its OCI instance principal;
# no OCI user API key/private key is stored here. Keep the matching age secret
# key OFF this VM (for example in a password manager).
OCI_BACKUP_BUCKET=
BACKUP_AGE_RECIPIENT=
